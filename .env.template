# Azure AI Foundry Configuration
# Copy this file to .env and fill in the values from your Azure deployment

# Azure AI Project endpoint (from 'azd env get-values' or Azure portal)
AZURE_AI_PROJECT_ENDPOINT=

# Azure AI Model deployment name (the GPT-4.1-mini deployment name)
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# Optional: Application Insights connection string for telemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Note: DefaultAzureCredential is used for authentication
# For local development, run 'az login' first
# For production, the managed identity will be used automatically
