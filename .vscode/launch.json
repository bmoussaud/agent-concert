{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Agent (Direct)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/agent.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Python: Agent (agentdev CLI)",
      "type": "debugpy",
      "request": "launch",
      "module": "agent_dev_cli",
      "args": [
        "run",
        "--port",
        "8088"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
